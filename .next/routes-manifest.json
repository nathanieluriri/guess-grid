{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' http://localhost:8000 https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        }
      ],
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/learn/[chapterId]/[lessonId]",
      "regex": "^/learn/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPchapterId": "nxtPchapterId",
        "nxtPlessonId": "nxtPlessonId"
      },
      "namedRegex": "^/learn/(?<nxtPchapterId>[^/]+?)/(?<nxtPlessonId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/play/[mode]",
      "regex": "^/play/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPmode": "nxtPmode"
      },
      "namedRegex": "^/play/(?<nxtPmode>[^/]+?)(?:/)?$"
    },
    {
      "page": "/play/[mode]/secret",
      "regex": "^/play/([^/]+?)/secret(?:/)?$",
      "routeKeys": {
        "nxtPmode": "nxtPmode"
      },
      "namedRegex": "^/play/(?<nxtPmode>[^/]+?)/secret(?:/)?$"
    },
    {
      "page": "/practice/[sessionId]",
      "regex": "^/practice/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPsessionId": "nxtPsessionId"
      },
      "namedRegex": "^/practice/(?<nxtPsessionId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/puzzles/[id]",
      "regex": "^/puzzles/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/puzzles/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/game",
      "regex": "^/game(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/game(?:/)?$"
    },
    {
      "page": "/inventory",
      "regex": "^/inventory(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/inventory(?:/)?$"
    },
    {
      "page": "/learn",
      "regex": "^/learn(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/learn(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/play",
      "regex": "^/play(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/play(?:/)?$"
    },
    {
      "page": "/play/bot/configure",
      "regex": "^/play/bot/configure(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/play/bot/configure(?:/)?$"
    },
    {
      "page": "/play/local/setup",
      "regex": "^/play/local/setup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/play/local/setup(?:/)?$"
    },
    {
      "page": "/play/online/queue",
      "regex": "^/play/online/queue(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/play/online/queue(?:/)?$"
    },
    {
      "page": "/practice",
      "regex": "^/practice(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/practice(?:/)?$"
    },
    {
      "page": "/profile",
      "regex": "^/profile(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/profile(?:/)?$"
    },
    {
      "page": "/profile/settings",
      "regex": "^/profile/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/profile/settings(?:/)?$"
    },
    {
      "page": "/puzzles",
      "regex": "^/puzzles(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/puzzles(?:/)?$"
    },
    {
      "page": "/puzzles/daily",
      "regex": "^/puzzles/daily(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/puzzles/daily(?:/)?$"
    },
    {
      "page": "/signup",
      "regex": "^/signup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/signup(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/social",
      "regex": "^/social(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/social(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}